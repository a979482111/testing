{
  "name": "test2-vue3",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -k \"pnpm dev\" \"pnpm --prefix backend dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "pnpm exec eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "deploy:build": "pnpm build && cd backend && pnpm install --prod",
    "start:prod": "cd backend && cross-env NODE_ENV=production node index.js"
  },
  "dependencies": {
    "pinia": "^2.1.0",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^8.49.0",
    "eslint-plugin-vue": "^9.17.0",
    "vite": "^5.0.0"
  }
}
